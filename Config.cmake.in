@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(SDL3 REQUIRED CONFIG COMPONENTS SDL3-shared)
find_dependency(glm REQUIRED)
find_dependency(spdlog REQUIRED)
find_dependency(fmt REQUIRED)
find_dependency(nlohmann_json REQUIRED)
find_dependency(sol2 REQUIRED)
find_dependency(assimp REQUIRED)
find_dependency(Freetype REQUIRED)
find_dependency(Jolt REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/rama-engineTargets.cmake")

check_required_components(rama-engine)
